{
	"name": "latte",
	"displayName": "Latte",
	"description": "Advanced Latte template syntax highlighting with PHP-aware attributes, Alpine.js support, Neon syntax, and snippets.",
	"version": "1.0.0",
	"publisher": "jan-herman",
	"author": {
		"name": "Jan Herman",
		"email": "mail@janherman.com",
		"url": "https://janherman.com"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jan-herman/vscode-latte.git"
	},
	"homepage": "https://github.com/jan-herman/vscode-latte",
	"bugs": {
		"url": "https://github.com/jan-herman/vscode-latte/issues"
	},
	"engines": {
		"vscode": "^1.84.0"
	},
	"main": "./out/extension.js",
	"activationEvents": [
		"onLanguage:latte"
	],
	"icon": "icon.png",
	"scripts": {
		"clear-build": "rm -rf ./out/*",
		"vscode:prepublish": "npm run clear-build && npm run esbuild-base -- --minify",
		"php-stubs": "php ./php-stubs/generator.php",
		"esbuild-base": "npm run php-stubs && esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
		"esbuild": "npm run esbuild-base -- --sourcemap",
		"esbuild-watch": "npm run esbuild-base -- --sourcemap --watch"
	},
	"categories": [
		"Programming Languages",
		"Snippets"
	],
	"keywords": [
		"latte",
		"nette",
		"neon",
		"php",
		"templates",
		"syntax-highlighting",
		"alpine.js",
		"snippets"
	],
	"dependencies": {
		"@flatten-js/interval-tree": "^1.1.1",
		"json5": "^2.2.3",
		"php-parser": "^3.1.5"
	},
	"devDependencies": {
		"@types/jest": "^29.5.8",
		"@types/node": "^20.9.0",
		"@types/vscode": "^1.84.1",
		"@vscode/vsce": "^2.22.0",
		"esbuild": "^0.19.5",
		"ts-node": "^10.9.1",
		"typescript": "^5.2.2"
	},
	"contributes": {
		"configuration": {
			"title": "Latte",
			"properties": {
				"latte.pathAliases": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "Maps Barista-style Latte template path alias prefixes to workspace-relative or absolute directories. Replacement paths may use `${workspaceFolder}`, `${relativePath}`, and `${relativePathWithoutExtension}`. `${relativePath}` is the normalized path segment after the matched alias, with leading and trailing slashes removed. `${relativePathWithoutExtension}` removes the final file extension from that segment. String aliases only; callable Barista aliases need explicit string mappings here. Example: `{ \"@components\": \"site/snippets/components\", \"@blocks\": \"src/blocks/${relativePathWithoutExtension}.template.latte\" }`."
				}
			}
		},
		"configurationDefaults": {
			"emmet.includeLanguages": {
				"latte": "html"
			}
		},
		"languages": [
			{
				"id": "neon",
				"aliases": [
					"Neon",
					"neon"
				],
				"extensions": [
					".neon"
				],
				"configuration": "./neon.configuration.json"
			},
			{
				"id": "latte",
				"aliases": [
					"Latte",
					"latte"
				],
				"extensions": [
					".latte"
				],
				"configuration": "./latte.configuration.json"
			}
		],
		"grammars": [
			{
				"language": "neon",
				"scopeName": "source.neon",
				"path": "./syntaxes/neon.json"
			},
			{
				"language": "latte",
				"scopeName": "text.html.latte",
				"path": "./syntaxes/latte.json",
				"embeddedLanguages": {
					"source.n-macro.latte": "php"
				}
			},
			{
				"scopeName": "latte.alpine-attribute.injection",
				"path": "./syntaxes/latte-alpine-attribute.injection.json",
				"injectTo": [
					"text.html.latte"
				],
				"embeddedLanguages": {
					"meta.embedded.inline.javascript.latte": "javascript"
				}
			},
			{
				"scopeName": "latte.alpine-interpolation.injection",
				"path": "./syntaxes/latte-alpine-interpolation.injection.json",
				"injectTo": [
					"text.html.latte"
				],
				"embeddedLanguages": {
					"meta.embedded.inline.php.latte": "php"
				}
			},
			{
				"scopeName": "latte.n-attribute.injection",
				"path": "./syntaxes/latte-n-attribute.injection.json",
				"injectTo": [
					"text.html.latte"
				],
				"embeddedLanguages": {
					"meta.embedded.inline.php.latte": "php"
				}
			},
			{
				"scopeName": "latte.attribute-interpolation.injection",
				"path": "./syntaxes/latte-attribute-interpolation.injection.json",
				"injectTo": [
					"text.html.latte"
				],
				"embeddedLanguages": {
					"meta.embedded.inline.php.latte": "php"
				}
			}
		],
		"snippets": [
			{
				"language": "latte",
				"path": "./snippets/snippets.json"
			}
		]
	}
}
