{
	"name": "latte",
	"displayName": "Nette Latte + Neon",
	"description": "Nette Latte + Neon support for VS Code",
	"version": "0.6.0",
	"publisher": "jan-herman",
	"engines": {
		"vscode": "^0.10.1"
	},
	"icon": "icon.png",
	"categories": [
		"Languages"
	],
	"galleryBanner": {
		"color": "#3484D3",
		"theme": "light"
	},
	"contributes": {
		"languages": [
			{
				"id": "neon",
				"aliases": [
					"Neon",
					"neon"
				],
				"extensions": [
					".neon"
				],
				"configuration": "./neon.configuration.json"
			},
			{
				"id": "latte",
				"aliases": [
					"Latte",
					"latte"
				],
				"extensions": [
					".latte"
				],
				"configuration": "./latte.configuration.json"
			}
		],
		"grammars": [
			{
				"language": "neon",
				"scopeName": "source.neon",
				"path": "./syntaxes/neon.json"
			},
			{
				"language": "latte",
				"scopeName": "source.latte",
				"path": "./syntaxes/latte.json"
			}
		],
		"snippets": [
			{
				"language": "latte",
				"path": "./snippets/snippets.json"
			}
		]
	}
}