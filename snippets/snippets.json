	},
	"|dataStream": {
		"prefix": "|dataStream",
		"body": "|dataStream${1::${2:mimetype}}",
		"description": "Create a data stream"
	},
	"|url": {
		"prefix": "|url",
		"body": "|url",
		"description": "Escape a URL"
	},
	"|length": {
		"prefix": "|length",
		"body": "|length",
		"description": "Get value length"
	},
	"|null": {
		"prefix": "|null",
		"body": "|null",
		"description": "Discard output"
	},
	"|sort": {
		"prefix": "|sort",
		"body": "|sort",
		"description": "Sort values"
	},
	"|reverse": {
		"prefix": "|reverse",
		"body": "|reverse",
		"description": "Reverse values"
	},
	"|clamp": {
		"prefix": "|clamp",
		"body": "|clamp: (${1:0, 255})",
		"description": "Clamp a value"
	},
	"|json": {
		"prefix": "|json",
		"body": "|json",
		"description": "Encode value as JSON"
	},
	"|translate": {
		"prefix": "|translate",
		"body": "|translate${1::${2:context}}",
		"description": "Translate filtered text"
	},
	"|nocheck": {
		"prefix": "|nocheck",
		"body": "|nocheck",
		"description": "Disable content checks for output"
	},
	"n:class": {
		"prefix": "n:class",
		"body": "n:class=\"${1:condition} ? ${2:active}\"",
		"description": "Conditional class attribute"
	},
	"n:attr": {
		"prefix": "n:attr",
		"body": "n:attr=\"${1:href} => ${2:\\$href}\"",
		"description": "Dynamic attributes"
	},
	"n:ifcontent": {
		"prefix": "n:ifcontent",
		"body": "n:ifcontent",
		"description": "Render element only when it has content"
	},
	"n:ifchanged": {
		"prefix": "n:ifchanged",
		"body": "n:ifchanged",
		"description": "Render element only when content changes"
	},
	"n:foreach": {
		"prefix": "n:foreach",
		"body": "n:foreach=\"${1:\\$items} as ${2:\\$item}\"",
		"description": "Loop element over items"
	},
	"n:inner-foreach": {
		"prefix": "n:inner-foreach",
		"body": "n:inner-foreach=\"${1:\\$items} as ${2:\\$item}\"",
		"description": "Loop element contents over items"
	},
	"n:tag-if": {
		"prefix": "n:tag-if",
		"body": "n:tag-if=\"${1:\\$condition}\"",
		"description": "Conditionally render the HTML tag"
	},
	"n:href": {
		"prefix": "n:href",
		"body": "n:href=\"${1:Presenter}:${2:action} ${3:\\$arg}\"",
		"description": "Presenter link attribute"
	},
	"n:snippet": {
		"prefix": "n:snippet",
		"body": "n:snippet=\"${1:content}\"",
		"description": "AJAX snippet attribute"
	},
	"n:name": {
		"prefix": "n:name",
		"body": "n:name=\"${1:fieldName}\"",
		"description": "Bind form element name"
	},
	"n:input": {
		"prefix": "n:input",
		"body": "n:input=\"${1:fieldName}\"",
		"description": "Bind form input"
	},
	"n:validation": {
		"prefix": "n:validation",
		"body": "n:validation=\"${1:fieldName}\"",
		"description": "Bind form validation"
	},
	"n:nonce": {
		"prefix": "n:nonce",
		"body": "n:nonce",
		"description": "Add CSP nonce attribute"
	}
}
