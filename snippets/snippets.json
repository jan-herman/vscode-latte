{
	"block": {
		"prefix": "block",
		"body": "{block ${1:content}}\n\t$0\n{/block}",
		"description": "Latte named block"
	},
	"block local": {
		"prefix": "block",
		"body": "{block local ${1:content}}\n\t$0\n{/block}",
		"description": "Latte local block"
	},
	"sandbox": {
		"prefix": "sandbox",
		"body": "{sandbox '${1:untrusted_example.latte}'}\n",
		"description": "Render an untrusted template in sandbox mode"
	},
	"try": {
		"prefix": "try",
		"body": "{try}\n\t$0\n{/try}",
		"description": "Latte try block"
	},
	"rollback": {
		"prefix": "rollback",
		"body": "{rollback}$0",
		"description": "Rollback a Latte try block"
	},
	"embed": {
		"prefix": "embed",
		"body": "{embed '${1:template.latte}'}\n\t$0\n{/embed}",
		"description": "Embed a template and override blocks"
	},
	"snippet": {
		"prefix": "snippet",
		"body": "{snippet ${1:content}}\n\t$0\n{/snippet}",
		"description": "Latte AJAX snippet block"
	},
	"import": {
		"prefix": "import",
		"body": "{import '${1:../@layout.latte}'}\n$0",
		"description": "Import blocks from another template"
	},
	"layout": {
		"prefix": "layout",
		"body": "{layout '${1:../@layout.latte}'}\n$0",
		"description": "Set the layout template"
	},
	"extends": {
		"prefix": "extends",
		"body": "{extends '${1:../@layout.latte}'}\n$0",
		"description": "Extend another template"
	},
	"capture": {
		"prefix": "capture",
		"body": "{capture \\$${1:var}}\n\t$0\n{/capture}",
		"description": "Capture rendered output into a variable"
	},
	"define": {
		"prefix": "define",
		"body": "{define ${1:content}}\n\t$0\n{/define}",
		"description": "Define a reusable block"
	},
	"include": {
		"prefix": "include",
		"body": "{include #${1:content}}\n$0",
		"description": "Include a block"
	},
	"include block": {
		"prefix": "include",
		"body": "{include block '${1:foo}'}\n$0",
		"description": "Include a named block"
	},
	"include file": {
		"prefix": "include",
		"body": "{include file '${1:foo}'}\n$0",
		"description": "Include a template file"
	},
	"include from": {
		"prefix": "include",
		"body": "{include block from '${1:template.latte}'}\n$0",
		"description": "Include a block from another template"
	},
	"foreach": {
		"prefix": "foreach",
		"body": "{foreach \\$${1:items} as \\$${2:item}}\n\t$0\n{/foreach}",
		"description": "Loop over items"
	},
	"while": {
		"prefix": "while",
		"body": "{while \\$${1:item} = \\$${2:items}->fetch()}\n\t$0\n{/while}",
		"description": "Latte while loop"
	},
	"iterateWhile": {
		"prefix": "iterateWhile",
		"body": "{iterateWhile}\n\t$0\n{/while}",
		"description": "Continue a foreach-style iteration"
	},
	"for": {
		"prefix": "for",
		"body": "{for \\$${1:i} = 0; \\$${1:i} < ${2:10}; \\$${1:i}++}\n\t$0\n{/for}",
		"description": "Latte for loop"
	},
	"first": {
		"prefix": "first",
		"body": "{first}\n\t$0\n{/first}",
		"description": "Render content only on first iteration"
	},
	"last": {
		"prefix": "last",
		"body": "{last}\n\t$0\n{/last}",
		"description": "Render content only on last iteration"
	},
	"sep": {
		"prefix": "sep",
		"body": "{sep}\n\t$0\n{/sep}",
		"description": "Render separator content between iterations"
	},
	"continueIf": {
		"prefix": "continueIf",
		"body": "{continueIf \\$${1:condition}}$0",
		"description": "Continue loop when condition is true"
	},
	"skipIf": {
		"prefix": "skipIf",
		"body": "{skipIf \\$${1:condition}}$0",
		"description": "Skip rendering when condition is true"
	},
	"switch": {
		"prefix": "switch",
		"body": "{switch ${1:expression}}\n\t{case ${2:value}}\n\t\t$0\n{/switch}",
		"description": "Latte switch block"
	},
	"breakIf": {
		"prefix": "breakIf",
		"body": "{breakIf \\$${1:condition}}$0",
		"description": "Break loop when condition is true"
	},
	"if": {
		"prefix": "if",
		"body": "{if \\$${1:condition}}\n\t$0\n{/if}",
		"description": "Latte if block"
	},
	"ifset": {
		"prefix": "ifset",
		"body": "{ifset \\$${1:var}}\n\t$0\n{/ifset}",
		"description": "Render when value is set"
	},
	"ifchanged": {
		"prefix": "ifchanged",
		"body": "{ifchanged ${1:expression}}\n\t$0\n{/ifchanged}",
		"description": "Render when expression changes"
	},
	"cache": {
		"prefix": "cache",
		"body": "{cache \\$${1:key}}\n\t$0\n{/cache}",
		"description": "Cache rendered template output"
	},
	"default": {
		"prefix": "default",
		"body": "{default \\$${1:foo} = ${2:''}}$0",
		"description": "Set a default template variable"
	},
	"link": {
		"prefix": "link",
		"body": "{link ${1:Default}}\n$0",
		"description": "Create a presenter link"
	},
	"plink": {
		"prefix": "plink",
		"body": "{plink ${1:Default}}\n$0",
		"description": "Create an absolute presenter link"
	},
	"control": {
		"prefix": "control",
		"body": "{control ${1:exampleSignForm}}\n$0",
		"description": "Render a Nette control"
	},
	"form": {
		"prefix": "form",
		"body": "{form ${1:exampleSignForm}}\n\t$0\n{/form}",
		"description": "Render a Nette form"
	},
	"formPrint": {
		"prefix": "formPrint",
		"body": "{formPrint ${1:exampleSignForm}}",
		"description": "Print a Nette form"
	},
	"varPrint": {
		"prefix": "varPrint",
		"body": "{varPrint ${1:example}}\n",
		"description": "Print variable type information"
	},
	"var": {
		"prefix": "var",
		"body": "{var \\$${1:name} = 'John Smith'}\n",
		"description": "Declare a template variable"
	},
	"parameters": {
		"prefix": "parameters",
		"body": "{parameters \n\t${1:?string} \\$${2:name},$0\n}",
		"description": "Declare template parameters"
	},
	"varType": {
		"prefix": "varType",
		"body": "{varType ${1:string} \\$${2:lang}}\n",
		"description": "Annotate a template variable type"
	},
	"templateType": {
		"prefix": "templateType",
		"body": "{templateType ${1:App\\Presenter\\ExampleDefaultTemplate}}\n",
		"description": "Annotate the template parameter class"
	},
	"templatePrint": {
		"prefix": "templatePrint",
		"body": "{templatePrint ${1:App\\Presenter\\ExampleDefaultTemplate}}\n",
		"description": "Generate template type information"
	},
	"label": {
		"prefix": "label",
		"body": "{label ${1:foo} /}\n",
		"description": "Render a form label"
	},
	"input": {
		"prefix": "input",
		"body": "{input ${1:foo}}\n",
		"description": "Render a form input"
	},
	"syntax": {
		"prefix": "syntax",
		"body": "{syntax ${1:mode}}\n\t$0\n{/syntax}",
		"description": "Switch Latte syntax mode"
	},
	"spaceless": {
		"prefix": "spaceless",
		"body": "{spaceless}\n\t$0\n{/spaceless}",
		"description": "Remove whitespace between HTML tags"
	},
	"l": {
		"prefix": "l",
		"body": "{l}$0",
		"description": "Print a literal opening brace"
	},
	"r": {
		"prefix": "r",
		"body": "{r}$0",
		"description": "Print a literal closing brace"
	},
	"comment": {
		"prefix": "comment",
		"body": "{* ${1:comment} *}$0",
		"description": "Latte block comment"
	},
	"translator": {
		"prefix": "_",
		"body": "{_'${1:text}'}$0",
		"description": "Translate a message"
	},
	"translator with context": {
		"prefix": "_",
		"body": "{_'${1:text}', ${2:context}}$0",
		"description": "Translate a message with context"
	},
	"ternary": {
		"prefix": "tern",
		"body": "{\\$${1:condition} ? ${2:'yes'} : ${3:'no'}}$0",
		"description": "Latte ternary expression"
	},
	"contentType": {
		"prefix": "contentType",
		"body": "{contentType ${1:application/xml}}\n$0",
		"description": "Set output content type"
	},
	"status": {
		"prefix": "status",
		"body": "{status ${1:500}}\n$0",
		"description": "Set HTTP response status"
	},
	"do": {
		"prefix": "do",
		"body": "{do ${1:code}}",
		"description": "Execute Latte expression without output"
	},
	"dump": {
		"prefix": "dump",
		"body": "{dump \\$${1:var}}\n$0",
		"description": "Dump a variable for debugging"
	},
	"php": {
		"prefix": "php",
		"body": "{php ${1:code}}\n$0",
		"description": "Run PHP code in a Latte tag"
	},
	"debugbreak": {
		"prefix": "debugbreak",
		"body": "{debugbreak \\$${1:condition}}\n$0",
		"description": "Trigger a debug break conditionally"
	},
	"clamp": {
		"prefix": "clamp",
		"body": "{=clamp(${1:level}, ${2:0}, ${3:255})}",
		"description": "Output a clamped value"
	},
	"|truncate": {
		"prefix": "|truncate",
		"body": "|truncate:${1:length}${2:,'${3:append}'}",
		"description": "Truncate text"
	},
	"|substr": {
		"prefix": "|substr",
		"body": "|substr:${1:offset}${2:,${3:length}}",
		"description": "Extract a substring"
	},
	"|trim": {
		"prefix": "|trim",
		"body": "|trim${1::'${2:charset}'}",
		"description": "Trim characters from text"
	},
	"|striptags": {
		"prefix": "|striptags",
		"body": "|striptags",
		"description": "Strip HTML tags"
	},
	"|strip": {
		"prefix": "|strip",
		"body": "|strip",
		"description": "Strip whitespace"
	},
	"|webalize": {
		"prefix": "|webalize",
		"body": "|webalize${1::'${2:charlist}'${3:,${4:lower}}}",
