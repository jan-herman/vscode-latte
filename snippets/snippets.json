	},
	"|replace": {
		"prefix": "|replace",
		"body": "|replace:'${1:search}'${2:,'${3:replace}'}",
		"description": "Replace text"
	},
	"|replaceRE": {
		"prefix": "|replaceRE",
		"body": "|replaceRE:'${1:pattern}'${2:,'${3:replace}'}",
		"description": "Replace text with a regular expression"
	},
	"|padLeft": {
		"prefix": "|padLeft",
		"body": "|padLeft:${1:length}${2:,'${3:pad}'}",
