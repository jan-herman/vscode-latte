	},
	"|padRight": {
		"prefix": "|padRight",
		"body": "|padRight:${1:length}${2:,'${3:pad}'}",
		"description": "Pad text on the right"
	},
	"|repeat": {
		"prefix": "|repeat",
		"body": "|repeat:${1:count}",
		"description": "Repeat text"
	},
	"|implode": {
		"prefix": "|implode",
		"body": "|implode:'${1:glue}'",
