	},
	"|nl2br": {
		"prefix": "|nl2br",
		"body": "|nl2br",
		"description": "Convert line breaks to br tags"
	},
	"|lower": {
		"prefix": "|lower",
		"body": "|lower",
		"description": "Lowercase text"
	},
	"|upper": {
		"prefix": "|upper",
		"body": "|upper",
		"description": "Uppercase text"
	},
	"|firstUpper": {
		"prefix": "|firstUpper",
		"body": "|firstUpper",
		"description": "Uppercase the first character"
	},
	"|capitalize": {
		"prefix": "|capitalize",
		"body": "|capitalize",
		"description": "Capitalize words"
	},
	"|date": {
		"prefix": "|date",
		"body": "|date:'${1:format}'",
		"description": "Format a date"
	},
	"|number": {
		"prefix": "|number",
		"body": "|number${1::${2:decimals}${3:,'${4:decPoint}'${5:,'${6:thousandsSep}'}}}",
