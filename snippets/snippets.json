	},
	"|toAscii": {
		"prefix": "|toAscii",
		"body": "|toAscii",
		"description": "Transliterate text to ASCII"
	},
	"|indent": {
		"prefix": "|indent",
		"body": "|indent${1::${2:level}${3:,'${4:char}'}}",
