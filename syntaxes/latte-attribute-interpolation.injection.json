{
    "scopeName": "latte.attribute-interpolation.injection",
    "injectionSelector": "L:meta.tag - string.quoted - meta.attribute.alpine.latte, L:string.quoted.double.html - meta.attribute.alpine.latte, L:string.quoted.single.html - meta.attribute.alpine.latte",
    "patterns": [
        {
            "include": "#double-quoted-attribute"
        },
        {
            "include": "#single-quoted-attribute"
        },
        {
            "include": "#attribute-interpolation"
        }
    ],
    "repository": {
        "double-quoted-attribute": {
            "begin": "(?<!\\S)(?!n:)([a-zA-Z_][-a-zA-Z0-9_:.]*)\\s*(=)\\s*(\")(?=[^\"\\n]*(?<!\\{)\\{(?![\\{\\*\\s'\"]))",
            "beginCaptures": {
                "1": {
                    "name": "entity.other.attribute-name.html"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html"
                },
                "3": {
                    "name": "punctuation.definition.string.begin.html"
                }
            },
            "end": "\"|(?=>\\s*$)|$",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.string.end.html"
                }
            },
            "name": "meta.attribute.interpolated.latte",
            "patterns": [
                {
                    "include": "#attribute-interpolation"
                },
                {
                    "match": "[^\"{]+|\\{",
                    "name": "string.quoted.double.html"
                }
            ]
        },
        "single-quoted-attribute": {
            "begin": "(?<!\\S)(?!n:)([a-zA-Z_][-a-zA-Z0-9_:.]*)\\s*(=)\\s*(')(?=[^'\\n]*(?<!\\{)\\{(?![\\{\\*\\s'\"]))",
            "beginCaptures": {
                "1": {
                    "name": "entity.other.attribute-name.html"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html"
                },
                "3": {
                    "name": "punctuation.definition.string.begin.html"
                }
            },
            "end": "'|(?=>\\s*$)|$",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.string.end.html"
                }
            },
            "name": "meta.attribute.interpolated.latte",
            "patterns": [
                {
                    "include": "#attribute-interpolation"
                },
                {
                    "match": "[^'{]+|\\{",
                    "name": "string.quoted.single.html"
                }
            ]
        },
        "attribute-interpolation": {
            "begin": "(?<!\\{)(\\{)(?![\\{\\*\\s'\"])",
            "beginCaptures": {
                "1": {
                    "name": "tag.begin.latte"
                }
            },
            "end": "\\/?\\}?\\}",
            "endCaptures": {
                "0": {
                    "name": "tag.end.latte"
                }
            },
            "name": "source.latte.embedded.html",
            "contentName": "meta.embedded.inline.php.latte",
            "patterns": [
                {
                    "include": "text.html.latte#latte-expression"
                }
            ]
        }
    }
}
