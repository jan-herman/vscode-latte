{
    "name": "Latte",
    "fileTypes": [
        "latte"
    ],
    "patterns": [
        {
            "begin": "\\{\\*",
            "end": "\\*\\}",
            "name": "comment.block.latte"
        },
        {
            "begin": "\\{\\{?(?!\\s|['\"])",
            "beginCaptures": [
                {
                    "name": "tag.begin.latte"
                }
            ],
            "end": "\\/?\\}?\\}",
            "endCaptures": [
                {
                    "name": "tag.end.latte"
                }
            ],
            "name": "source.latte",
            "patterns": [
                {
                    "include": "#latte-expression"
                }
            ]
        },
        {
            "begin": "(?:\\b(n:)|(:|@|#))([a-zA-Z0-9\\-_]+)(?:\\:([a-zA-Z\\-_]+))?(?:\\.([a-zA-Z\\-_]+))*\\s*(=)",
            "end": "(?<='|\")|(?=[\\s<>`])",
            "name": "meta.attribute.n-macro.latte",
            "captures": {
                "1": {
                    "name": "entity.other.attribute-name.html"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html"
                },
                "3": {
                    "name": "entity.other.attribute-name.html"
                },
                "4": {
                    "name": "entity.other.attribute-name.html"
                },
                "5": {
                    "name": "entity.other.attribute-name.html"
                },
                "6": {
                    "name": "punctuation.separator.key-value.html"
                }
            },
            "patterns": [
                {
                    "name": "source.n-macro.latte",
                    "begin": "\"",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.html"
                        }
                    },
                    "end": "\"",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.html"
                        }
                    },
                    "patterns": [
                        {
                            "include": "source.php"
                        }
                    ]
                }

            ]
        },
        {
            "include": "#dynamic-html-tag"
        },
        {
            "include": "text.html.basic"
        }
    ],
    "repository": {
        "latte-expression": {
            "patterns": [
                {
                    "include": "#latte-tag-bang"
                },
                {
                    "include": "#php-block-comment"
                },
                {
                    "include": "#latte-control-single"
                },
                {
                    "include": "#latte-control-pair"
                },
                {
                    "include": "#latte-content-type"
                },
                {
                    "include": "#latte-block-name"
                },
                {
                    "include": "#latte-template-type"
                },
                {
                    "include": "#latte-parameter-type"
                },
                {
                    "include": "#latte-named-argument-leading"
                },
                {
                    "include": "#latte-named-argument-after-comma"
                },
                {
                    "include": "#latte-filter-named-argument"
                },
                {
                    "include": "#latte-include-modifier"
                },
                {
                    "include": "#latte-array"
                },
                {
                    "include": "#latte-array-key"
                },
                {
                    "include": "#latte-expand-operator"
                },
                {
                    "include": "#latte-parenthesized-expression"
                },
                {
                    "include": "#latte-function-call"
                },
                {
                    "include": "#latte-filter"
                },
                {
                    "include": "#latte-conditional-operator"
                },
                {
                    "include": "#latte-operator"
                },
                {
                    "include": "#latte-unquoted-string"
                },
                {
                    "include": "source.php"
                }
            ]
        },
        "dynamic-html-tag": {
            "patterns": [
                {
                    "include": "#dynamic-html-tag-start"
                },
                {
                    "include": "#dynamic-html-tag-end"
                }
            ]
        },
        "dynamic-html-tag-start": {
            "begin": "(<)([a-zA-Z][a-zA-Z0-9:_-]*)(?=\\{)",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.begin.html"
                },
                "2": {
                    "name": "entity.name.tag.html"
                }
            },
            "end": "/?>",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.tag.end.html"
                }
            },
            "name": "meta.tag.dynamic.start.html",
            "patterns": [
                {
                    "include": "#dynamic-tag-name-interpolation"
                },
                {
                    "match": "(?<=\\})[a-zA-Z0-9:_-]+|[a-zA-Z0-9:_-]+(?=\\{)",
                    "name": "entity.name.tag.html"
                },
                {
                    "include": "text.html.basic#attribute"
                }
            ]
        },
        "dynamic-html-tag-end": {
            "begin": "(</)([a-zA-Z][a-zA-Z0-9:_-]*)(?=\\{)",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.begin.html"
                },
                "2": {
                    "name": "entity.name.tag.html"
                }
            },
            "end": ">",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.tag.end.html"
                }
            },
            "name": "meta.tag.dynamic.end.html",
            "patterns": [
                {
                    "include": "#dynamic-tag-name-interpolation"
                },
                {
                    "match": "(?<=\\})[a-zA-Z0-9:_-]+|[a-zA-Z0-9:_-]+(?=\\{)",
                    "name": "entity.name.tag.html"
                }
            ]
        },
        "dynamic-tag-name-interpolation": {
            "begin": "(?<!\\{)(\\{)(?![\\{\\*\\s'\"])",
            "beginCaptures": {
                "1": {
                    "name": "tag.begin.latte"
                }
            },
            "end": "\\/?\\}?\\}",
            "endCaptures": {
                "0": {
                    "name": "tag.end.latte"
                }
            },
            "name": "source.latte.embedded.html",
            "contentName": "meta.embedded.inline.php.latte",
            "patterns": [
                {
                    "include": "#latte-expression"
                }
            ]
        },
        "latte-tag-bang": {
            "match": "(?<=\\{)(\\![^}]*)",
            "name": "keyword.latte"
        },
        "php-block-comment": {
            "begin": "/\\*",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.comment.begin.php"
                }
            },
            "end": "\\*/",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.comment.end.php"
                }
            },
            "name": "comment.block.php.latte"
        },
        "latte-control-single": {
            "match": "(?<=\\{)(?:_|=|(?:asset|breakIf|case|continueIf|contentType|control|debugbreak|default|do|dump|elseifset|elseif|else|exitIf|extends|import|includeblock|include|inputError|input|layout|linkBase|link|l|parameters|php|plink|preload|r|rollback|status|sandbox|skipIf|templatePrint|templateType|trace|use|var|varPrint|varType|component|icon|inlineSvg|image)(?=\\s|\\}|/\\}|\\|))",
            "name": "keyword.control.single.latte"
        },
        "latte-control-pair": {
            "match": "(?<=\\{)\/?(block|cache|capture|define|embed|first|foreach|formContainer|form|for|ifset|ifCurrent|ifchanged|if|label|last|sandbox|sep|snippetArea|snippet|spaceless|switch|syntax|translate|try|iterateWhile|while|each|loop)(?=\\s|\\}|/\\}|\\|)",
            "name": "keyword.control.pair.latte"
        },
        "latte-content-type": {
            "match": "(?<=\\{contentType\\s)([a-zA-Z][a-zA-Z0-9.+-]*/[a-zA-Z0-9.+-]+|html|xml|javascript|css|calendar|text)\\b",
            "name": "constant.language.content-type.latte"
        },
        "latte-block-name": {
            "patterns": [
                {
                    "captures": {
                        "1": {
                            "name": "entity.name.section.latte"
                        }
                    },
                    "match": "(?<=\\{block\\s)([a-zA-Z_][a-zA-Z0-9_-]*)"
                },
                {
                    "captures": {
                        "1": {
                            "name": "entity.name.section.latte"
                        }
                    },
                    "match": "(?<=\\{define\\s)([a-zA-Z_][a-zA-Z0-9_-]*)"
                },
                {
                    "captures": {
                        "1": {
                            "name": "entity.name.section.latte"
                        }
                    },
                    "match": "(?<=\\{include\\s)([a-zA-Z_][a-zA-Z0-9_-]*)"
                },
                {
                    "captures": {
                        "1": {
                            "name": "entity.name.section.latte"
                        }
                    },
                    "match": "(?<=\\{ifset\\s)([a-zA-Z_][a-zA-Z0-9_-]*)"
                }
            ]
        },
        "latte-operator": {
            "match": "(?<=\\s)(as\\b|in\\b)\\s?",
            "name": "keyword.operator.latte"
        },
        "latte-template-type": {
            "captures": {
                "2": {
                    "patterns": [
                        {
                            "include": "source.php#php-types"
                        }
                    ]
                }
            },
            "match": "(?<=\\{templateType)(\\s+)([^}\\|]+?)\\s*(?=\\}|/\\}|\\|)"
        },
        "latte-parameter-type": {
            "captures": {
                "1": {
                    "patterns": [
                        {
                            "include": "source.php#php-types"
                        }
                    ]
                }
            },
            "match": "(?<![$\\\\\\w.])(?!(?:as|in|and|or|xor|AS|IN|AND|OR|XOR)\\b)((?:\\?\\s*)?[\\\\(a-zA-Z_][a-zA-Z0-9_\\\\()]*\\s*(?:[|&]\\s*[\\\\(a-zA-Z_][a-zA-Z0-9_\\\\()]*\\s*)*)\\s+(?=\\$|\\.\\.\\.\\$)"
        },
        "latte-named-argument-leading": {
            "captures": {
                "1": {
                    "name": "variable.parameter.latte"
                },
                "2": {
                    "name": "punctuation.separator.key-value.latte"
                }
            },
            "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)"
        },
        "latte-named-argument-after-comma": {
            "captures": {
                "1": {
                    "name": "variable.parameter.latte"
                },
                "2": {
                    "name": "punctuation.separator.key-value.latte"
                }
            },
            "match": "(?<=,)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)"
        },
        "latte-filter-named-argument": {
            "captures": {
                "1": {
                    "name": "variable.parameter.latte"
                },
                "2": {
                    "name": "punctuation.separator.key-value.latte"
                }
            },
            "match": "(?<=:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)"
        },
        "latte-include-modifier": {
            "match": "(?<=\\s)(with|blocks|from)(?=\\s|\\})",
            "name": "keyword.other.modifier.latte"
        },
        "latte-array-key": {
            "captures": {
                "1": {
                    "name": "variable.parameter.latte"
                },
                "2": {
                    "name": "punctuation.separator.key-value.latte"
                }
            },
            "match": "(?:^|\\G|(?<=[\\[,]))\\s*([a-zA-Z_][a-zA-Z0-9_-]*)(\\s*:)(?!:)"
        },
        "latte-array": {
            "begin": "\\[",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.section.array.begin.php"
                }
            },
            "end": "\\]",
            "endCaptures": {
                "0": {
                    "name": "punctuation.section.array.end.php"
                }
            },
            "patterns": [
                {
                    "include": "#latte-expression"
                }
            ]
        },
        "latte-expand-operator": {
            "match": "\\(\\s*expand\\s*\\)",
            "name": "keyword.operator.spread.latte"
        },
        "latte-parenthesized-expression": {
            "begin": "\\(",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.begin.bracket.round.php"
                }
            },
            "end": "\\)",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.end.bracket.round.php"
                }
            },
            "patterns": [
                {
                    "include": "#latte-expression"
                }
            ]
        },
        "latte-function-call": {
            "begin": "(?<!->)(?<!::)\\b(?!fn\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()(?=[^)\\n]*(?:\\?\\|\\s*[a-zA-Z_]|\\|\\s*[a-zA-Z_]|(?<![$>\\\\\\w.-])(?!(?:true|false|null|TRUE|FALSE|NULL|and|or|xor|as|in)\\b)[a-z_][a-zA-Z0-9_.-]*\\s*(?:[,)])))",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.function.php"
                },
                "2": {
                    "name": "punctuation.definition.arguments.begin.bracket.round.php"
                }
            },
            "end": "\\)",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.arguments.end.bracket.round.php"
                }
            },
            "name": "meta.function-call.php",
            "patterns": [
                {
                    "include": "#latte-expression"
                }
            ]
        },
        "latte-filter": {
            "captures": {
                "1": {
                    "name": "keyword.other.latte"
                },
                "2": {
                    "name": "keyword.other.latte"
                }
            },
            "match": "(?<![\\?\\|])(\\?\\||\\|)(?!\\|)\\s*([a-zA-Z_][a-zA-Z0-9_]*)"
        },
        "latte-conditional-operator": {
            "match": "\\?(?!\\?|->)",
            "name": "keyword.operator.conditional.latte"
        },
        "latte-unquoted-string": {
            "match": "(?<![\\$>:\\\\\\w.-])(?!(?:[\\p{L}_][\\p{L}\\p{N}_.-]*\\\\))(?!(?:and|array|as|clone|default|false|in|instanceof|new|null|or|return|true|xor|AND|ARRAY|AS|CLONE|DEFAULT|FALSE|IN|INSTANCEOF|NEW|NULL|OR|RETURN|TRUE|XOR)\\b)(?![A-Z_]+\\b)(?:[\\p{L}_][\\p{L}\\p{N}_.-]*[\\p{L}\\p{N}_.]|[\\p{L}_]|[^\\x00-\\x7F\\s,\\[\\]\\(\\)\\{\\}:|?=<>!+\\/*'\"`.-]+)(?![\\p{L}\\p{N}_.-])(?!\\s*(?:\\(|::|->))",
            "name": "string.unquoted.latte"
        }
    },
    "scopeName": "text.html.latte"
}
