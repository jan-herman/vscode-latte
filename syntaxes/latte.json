{
    "name": "Latte",
    "fileTypes": [
        "latte"
    ],
    "patterns": [
        {
            "begin": "\\{\\*",
            "end": "\\*\\}",
            "name": "comment.block.latte"
        },
        {
            "begin": "\\{\\{?(?!\\s)",
            "beginCaptures": [
                {
                    "name": "tag.begin.latte"
                }
            ],
            "end": "\\/?\\}?\\}",
            "endCaptures": [
                {
                    "name": "tag.end.latte"
                }
            ],
            "name": "source.latte",
            "patterns": [
                {
                    "include": "#latte-tag-bang"
                },
                {
                    "include": "#latte-number"
                },
                {
                    "include": "#latte-variable"
                },
                {
                    "include": "#latte-constant-language"
                },
                {
                    "include": "#latte-control-single"
                },
                {
                    "include": "#latte-control-pair"
                },
                {
                    "include": "#latte-block-name"
                },
                {
                    "include": "#latte-operator"
                },
                {
                    "include": "#latte-object-operator"
                },
                {
                    "include": "#method-call"
                },
                {
                    "include": "#property-access"
                },
                {
                    "include": "#latte-nullable-type"
                },
                {
                    "include": "#latte-named-argument-leading"
                },
                {
                    "include": "#latte-named-argument-after-comma"
                },
                {
                    "include": "#latte-filter"
                },
                {
                    "include": "#strings"
                },
                {
                    "include": "source.php"
                }
            ]
        },
        {
            "begin": "(?:\\b(n:)|(:|@|#))([a-zA-Z0-9\\-_]+)(?:\\:([a-zA-Z\\-_]+))?(?:\\.([a-zA-Z\\-_]+))*\\s*(=)",
            "end": "(?<='|\")|(?=[\\s<>`])",
            "name": "meta.attribute.n-macro.latte",
            "captures": {
                "1": {
                    "name": "entity.other.attribute-name.html"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html"
                },
                "3": {
                    "name": "entity.other.attribute-name.html"
                },
                "4": {
                    "name": "entity.other.attribute-name.html"
                },
                "5": {
                    "name": "entity.other.attribute-name.html"
                },
                "6": {
                    "name": "punctuation.separator.key-value.html"
                }
            },
            "patterns": [
                {
                    "name": "source.n-macro.latte",
                    "begin": "\"",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin.html"
                        }
                    },
                    "end": "\"",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end.html"
                        }
                    },
                    "patterns": [
                        {
                            "include": "source.php"
                        }
                    ]
                }

            ]
        },
        {
            "include": "text.html.basic"
        }
    ],
    "repository": {
        "latte-tag-bang": {
            "match": "(?<=\\{)(\\![^}]*)",
            "name": "keyword.latte"
        },
        "latte-number": {
            "match": "\\b((0(x|X)[0-9a-fA-F]*)|(([0-9]+\\.?[0-9]*)|(\\.[0-9]+))((e|E)(\\+|-)?[0-9]+)?)\\b",
            "name": "constant.numeric.latte"
        },
        "latte-variable": {
            "match": "\\$\\$?[a-zA-Z_0-9]+\\s*",
            "name": "variable.other.latte"
        },
        "latte-constant-language": {
            "match": "true|TRUE|True|false|FALSE|False|null|NULL|Null",
            "name": "constant.language.latte"
        },
        "latte-control-single": {
            "match": "(?<=\\{)(_|=|breakIf|case|continueIf|contentType|control|debugbreak|default|do|dump|elseifset|elseif|else|exitIf|extends|import|includeblock|include|inputError|input|layout|link|parameters|php|plink|r|status|sandbox|skipIf|templatePrint|templateType|trace|use|var|varPrint|varType|component|icon|inlineSvg|image)\\s*",
            "name": "keyword.control.single.latte"
        },
        "latte-control-pair": {
            "match": "(?<=\\{)\/?(block|cache|capture|define|embed|first|foreach|form|for|ifset|ifCurrent|ifchanged|if|label|last|l|sandbox|sep|snippetArea|snippet|spaceless|switch|syntax|try|iterateWhile|while|each|loop)\\s*",
            "name": "keyword.control.pair.latte"
        },
        "latte-block-name": {
            "captures": {
                "1": {
                    "name": "entity.name.section.latte"
                }
            },
            "match": "(?<=\\{block\\s)([a-zA-Z_][a-zA-Z0-9_-]*)"
        },
        "latte-operator": {
            "match": "(?<=\\s)(\\!|\/|===|as|and|AND|And|&&|or|OR|Or|\\|\\||\\+\\+|\\-\\-|==|<=>|>=|<=)\\s?",
            "name": "keyword.operator.latte"
        },
        "latte-object-operator": {
            "match": "->",
            "name": "keyword.operator.latte"
        },
        "method-call": {
            "captures": {
                "1": {
                    "name": "entity.name.function.php"
                }
            },
            "match": "(?<=->)([a-zA-Z_][a-zA-Z_0-9]*)(?=\\s*\\()",
            "name": "meta.method-call.php"
        },
        "property-access": {
            "captures": {
                "1": {
                    "name": "variable.other.property.php"
                }
            },
            "match": "(?<=->)([a-zA-Z_][a-zA-Z_0-9]*)(?![a-zA-Z_0-9])(?!(?:\\s*\\())"
        },
        "latte-nullable-type": {
            "captures": {
                "1": {
                    "name": "keyword.operator.type.nullable.latte"
                },
                "2": {
                    "name": "storage.type.php"
                }
            },
            "match": "(?:(\\?)(?!->))?(\\\\?[a-zA-Z_][a-zA-Z_0-9]*(?:\\\\[a-zA-Z_][a-zA-Z_0-9]*)*)(?=\\s+(?:\\$|\\.\\.\\.\\$))"
        },
        "latte-named-argument-leading": {
            "captures": {
                "1": {
                    "name": "variable.parameter.latte"
                },
                "2": {
                    "name": "punctuation.separator.key-value.latte"
                }
            },
            "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)"
        },
        "latte-named-argument-after-comma": {
            "captures": {
                "1": {
                    "name": "variable.parameter.latte"
                },
                "2": {
                    "name": "punctuation.separator.key-value.latte"
                }
            },
            "match": "(?<=,)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)"
        },
        "latte-filter": {
            "captures": {
                "1": {
                    "name": "keyword.other.latte"
                },
                "2": {
                    "name": "keyword.other.latte"
                }
            },
            "match": "(?<!\\|)(\\|)(?!\\|)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s*\\:[^\\|\\}]*)*"
        },
        "latte-bareword": {
            "match": "\\b(?!(?:abstract|and|array|as|break|callable|case|catch|class|clone|const|continue|declare|default|die|do|echo|else|elseif|empty|enddeclare|endfor|endforeach|endif|endswitch|endwhile|enum|eval|exit|extends|false|final|finally|fn|for|foreach|from|function|global|goto|if|implements|include|include_once|in|instanceof|insteadof|interface|isset|list|match|namespace|new|null|or|parent|print|private|protected|public|readonly|require|require_once|return|self|static|switch|throw|trait|true|try|unset|use|var|while|xor|yield)\\b)[a-z][a-zA-Z0-9_]*\\b(?!\\s*(?:\\(|::|->))"
        },
        "strings": {
            "patterns": [
                {
                    "match": "(')(.*?)(')",
                    "name": "string.quoted.single.latte"
                },
                {
                    "match": "(\")(.*?)(\")",
                    "name": "string.quoted.double.latte"
                }
            ]
        }
    },
    "scopeName": "text.html.latte"
}
